# --- Core ---
PORT=5000
# On Render this is provided automatically; locally 5000 is fine.
MONGO_URI=mongodb://localhost:27017/library_system
NODE_ENV=development

# --- Auth (use long random strings; generate with: openssl rand -hex 48) ---
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# --- Frontend origin (used for CORS + email links) ---
# Local: http://localhost:5173   Production: your Vercel URL
CLIENT_URL=http://localhost:5173

# --- Email via Resend (optional in dev: links print to the server console) ---
# Get an API key at https://resend.com (free tier). Leave blank to log emails.
RESEND_API_KEY=
# From address. The default onboarding sender only delivers to your own Resend
# account email — use a verified-domain address to email real users.
EMAIL_FROM=LibreNet Library <onboarding@resend.dev>

# --- Cloudinary (file uploads; required for durable uploads in production) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
