# --- Core ---
PORT=5000
# On Render this is provided automatically; locally 5000 is fine.
MONGO_URI=mongodb://localhost:27017/library_system
NODE_ENV=development

# --- Auth (use long random strings; generate with: openssl rand -hex 48) ---
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# --- Frontend origin (used for CORS + email links) ---
# Local: http://localhost:5173   Production: your Vercel URL
CLIENT_URL=http://localhost:5173

# --- Email via SMTP / nodemailer (optional in dev: links print to the console) ---
# Leave any of these blank to skip sending and log emails to the server console.
# For Gmail: host smtp.gmail.com, port 587, EMAIL_USER your address, and
# EMAIL_PASS a 16-char App Password (requires 2FA — not your normal password).
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
# From address. Defaults to "LibreNet Library <EMAIL_USER>" when left blank.
EMAIL_FROM=

# --- Cloudinary (file uploads; required for durable uploads in production) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
